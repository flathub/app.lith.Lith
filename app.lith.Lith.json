{
    "id": "app.lith.Lith",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.6",
    "sdk": "org.kde.Sdk",
    "command": "Lith",
    "finish-args": [
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--share=ipc",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=com.canonical.indicator.application",
        "--talk-name=org.ayatana.indicator.application",
        "--talk-name=org.freedesktop.secrets"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/cmake",
        "/lib/debug/source",
        "/mkspecs",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "qcoro",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_CXX_FLAGS=-fPIC"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/danvratil/qcoro",
                    "tag": "v0.13.0",
                    "commit": "98f23d8d8d67e9e24217d268927faec97c713fb0",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "libsecret",
            "buildsystem": "meson",
            "config-opts": [
                "-Dvapi=false",
                "-Dgtk_doc=false",
                "-Dbash_completion=disabled",
                "-Dmanpage=false",
                "-Dintrospection=false"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/GNOME/libsecret",
                    "tag": "0.21.7",
                    "commit": "0936f740c02b60f02657729cd99f581db4517a41",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_WITH_QT6=ON",
                "-DUSE_CREDENTIAL_STORE=ON",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DBUILD_TRANSLATIONS=OFF",
                "-DCMAKE_CXX_FLAGS=-fPIC"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frankosterfeld/qtkeychain",
                    "tag": "0.15.0",
                    "commit": "ad7344c45a86a4f66cbafc4b081b5f7b876cb0b7",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "Lith",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/LithApp/Lith",
                    "tag": "v1.6.17",
                    "commit": "c3d6fcfeb0b4d2c336c75f11d2f934f69f62f094",
                    "x-checker-data": {
                        "is-main-source": true,
                        "type": "git",
                        "tag-pattern": "^v([\\d]+[.][\\d.]*[02468][.][\\d]+)$"
                    }
                }
            ]
        }
    ]
}
