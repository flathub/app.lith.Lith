{
    "id": "app.lith.Lith",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.8",
    "sdk": "org.kde.Sdk",
    "command": "Lith",
    "finish-args": [
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--share=ipc",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=com.canonical.indicator.application",
        "--talk-name=org.ayatana.indicator.application",
        "--talk-name=org.freedesktop.secrets"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/cmake",
        "/lib/debug/source",
        "/mkspecs",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "qcoro",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_CXX_FLAGS=-fPIC"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/danvratil/qcoro",
                    "tag": "v0.11.0",
                    "commit": "3a6efdbe6a2a4b7fef9093b564a14ad1e046e9a4",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "libsecret",
            "buildsystem": "meson",
            "config-opts": [
                "-Dvapi=false",
                "-Dgtk_doc=false",
                "-Dbash_completion=disabled",
                "-Dmanpage=false",
                "-Dintrospection=false"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/GNOME/libsecret",
                    "tag": "0.21.6",
                    "commit": "e59012225c2857d53738574423416b541f11a131",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_WITH_QT6=ON",
                "-DUSE_CREDENTIAL_STORE=ON",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DBUILD_TRANSLATIONS=OFF",
                "-DCMAKE_CXX_FLAGS=-fPIC"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/frankosterfeld/qtkeychain",
                    "tag": "0.15.0",
                    "commit": "ad7344c45a86a4f66cbafc4b081b5f7b876cb0b7",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        },
        {
            "name": "Lith",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/LithApp/Lith",
                    "tag": "v1.6.6",
                    "commit": "feb64d6d1e112889ca4e78fb5b5b859d001d72a8",
                    "x-checker-data": {
                        "is-main-source": true,
                        "type": "git",
                        "tag-pattern": "^v([\\d]+[.][\\d.]*[02468][.][\\d]+)$"
                    }
                }
            ]
        }
    ]
}
